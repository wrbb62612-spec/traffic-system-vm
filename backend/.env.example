# 优先级：QWEN_API_KEY > DASHSCOPE_API_KEY > OPENAI_API_KEY（均从系统环境变量读取）
# 如果你的 key 已存在系统环境变量，此处可不填（留空或保留占位符）
# 优先读取顺序：QWEN_API_KEY → DASHSCOPE_API_KEY → OPENAI_API_KEY（已在 Windows 环境变量中配置则无需填写）
# QWEN_API_KEY=sk-xxxx
QWEN_MODEL=qwen3.5-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认使用占位预测器。接入 DCRNN 后改为 dcrnn
PREDICTOR_BACKEND=stub

# DCRNN 推理微服务地址（需先在 DCRNN 环境中启动 infer_service.py）
# 启动方式: cd d:/4C/DCRNN && python ../traffic-system/model_bundle/infer_service.py
INFER_SERVICE_URL=http://localhost:5001
INFER_SERVICE_TIMEOUT=30

# 离线热力图 JSON 路径（相对于 backend/ 目录）
OFFLINE_HEATMAP_PATH=data/offline_heatmap.json

# model_bundle 目录（sensor_meta.json、scaler.json 所在位置）
MODEL_BUNDLE_PATH=../model_bundle

# -------------------------------
# LA 外部数据 API（按需配置）
# -------------------------------
# NWS 无需 key，但建议设置自定义 UA（带联系方式）
WEATHER_USER_AGENT=traffic-system/0.1 (contact: admin@example.com)

# 节假日国家代码（默认 US）
NAGER_COUNTRY_CODE=US

# 外部数据落库与定时采集
EXTERNAL_DB_PATH=data/external_data.db
EXTERNAL_COLLECTION_ENABLED=true
EXTERNAL_COLLECTION_INTERVAL_SEC=300
EXTERNAL_DEFAULT_LAT=34.0522
EXTERNAL_DEFAULT_LON=-118.2437
EXTERNAL_DEFAULT_RADIUS_KM=8.0
EXTERNAL_DEFAULT_CITY=Los Angeles
EXTERNAL_DEFAULT_STATE_CODE=CA
EXTERNAL_DEFAULT_COUNTRY_CODE=US

# 外部数据源缓存 TTL（秒）
EXTERNAL_CACHE_WEATHER_TTL_SEC=300
EXTERNAL_CACHE_HOLIDAY_TTL_SEC=86400
EXTERNAL_CACHE_EVENTS_TTL_SEC=1800
EXTERNAL_CACHE_POI_TTL_SEC=21600
EXTERNAL_CACHE_INCIDENTS_TTL_SEC=300
